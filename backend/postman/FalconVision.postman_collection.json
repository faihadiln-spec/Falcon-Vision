    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Organization",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now();",
                  "pm.collectionVariables.set('organization_name', `Falcon Steel Factory ${suffix}`);",
                  "pm.collectionVariables.set('admin_email', `admin.${suffix}@example.com`);",
                  "pm.collectionVariables.set('admin_password', 'StrongPass123');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register organization returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "if (body.user && body.user.email) {",
                  "  pm.collectionVariables.set('admin_email', body.user.email);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organization_name\": \"{{organization_name}}\",\n  \"industry\": \"manufacturing\",\n  \"country\": \"Saudi Arabia\",\n  \"city\": \"Riyadh\",\n  \"address\": \"Industrial Zone 2\",\n  \"admin_full_name\": \"Admin User\",\n  \"admin_email\": \"{{admin_email}}\",\n  \"admin_password\": \"{{admin_password}}\",\n  \"admin_phone\": \"+966500000000\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register-organization",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register-organization"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "if (body.access_token) {",
                  "  pm.collectionVariables.set('access_token', body.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
